# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Square (本番)
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=production
SQUARE_LOCATION_IDS=L1234,L5678
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# LINE Messaging API (公式 LINE)
# https://developers.line.biz/console/ で Messaging API チャンネルを作成して取得
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# Anthropic Claude API (AI 目標提案用、任意)
# https://console.anthropic.com/ で API キーを取得
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps Geocoding API (任意・住所→座標変換)
# 未設定時は OpenStreetMap Nominatim を自動利用 (無料・レート制限あり)
# https://console.cloud.google.com/ > Geocoding API を有効化して取得
GOOGLE_MAPS_API_KEY=

# Gmail プッシュ通知連携 (HPB / minimo の予約通知メール自動取り込み)
# 詳細手順は README の「Gmail プッシュ通知セットアップ」を参照
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Pub/Sub トピック (例: projects/your-project-id/topics/gmail-vivie)
GMAIL_PUBSUB_TOPIC=
# Push エンドポイントのアクセス検証用シークレット
GMAIL_PUBSUB_VERIFICATION_TOKEN=

# アプリ設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ADMIN_EMAIL=admin@example.com
